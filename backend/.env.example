# TravelLink-List Backend Configuration
# Copy this file to .env and update values for your environment

# Server Configuration
PORT=8080
APP_ENV=local

# Database Configuration
DB_TYPE=sqlite3
DB_PATH=backend/travellink.db

# For PostgreSQL (if switching from SQLite3):
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=travellink
# DB_USERNAME=postgres
# DB_PASSWORD=password
# DB_SCHEMA=public
